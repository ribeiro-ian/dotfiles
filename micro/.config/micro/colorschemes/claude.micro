# ────────────────────────────────────────────────────────────────
# Claude Dark Theme
# ────────────────────────────────────────────────────────────────
#
# TERMINAL NAMED COLORS (use these for universal compatibility):
#   black, red, green, yellow, blue, magenta, cyan, white
#   brightblack, brightred, brightgreen, brightyellow,
#   brightblue, brightmagenta, brightcyan, brightwhite
#
# TEXT STYLES (add before color, space separated):
#   bold, italic, underline, bold italic, etc.
#
# HEX COLORS (true color - requires terminal support):
#   "#RRGGBB" - 24-bit RGB
#
# FOREGROUND,BACKGROUND (comma separates fg from bg):
#   "color"           -> fg only
#   ",color"          -> bg only
#   "color,color"     -> fg and bg
#   "bold color,bg"   -> style + fg + bg
#
# SUBGROUPS (fall back to parent if not defined):
#   constant.string -> if missing, uses constant
#   identifier.class -> if missing, uses identifier
#
# ────────────────────────────────────────────────────────────────
# Color Palette
# ────────────────────────────────────────────────────────────────
# #1A1917 -> Background
# #EDE8E0 -> Foreground
# #DA7756 -> Accent
# #6B6560 -> Comment
# #D95C5C -> Red
# #5BAF7A -> Green
# #7AABE0 -> Blue
# #D4943A -> Yellow
# #4EC2C2 -> Cyan
# #A584E0 -> Magenta
# #9A928A -> Gray
# #1F1E1C -> Surface
# #262422 -> Panels
# #35322E -> Hover
# #3D3A35 -> Selected
# #C96642 -> Secundary accent
# ────────────────────────────────────────────────────────────────

# ─────── BASE ──────────────────────────────────────────────────
# Default: background and foreground for unhighlighted text
color-link default "#EDE8E0,#1A1917"
# Comments: usually italic in most editors
color-link comment "italic #6B6560"

# ─────── IDENTIFIERS ───────────────────────────────────────────
# General variable/function names
color-link identifier "#EDE8E0"
# Class names (PascalCase/CamelCase types)
color-link identifier.class "#DA7756"
# Variable declarations (let, const, var)
color-link identifier.var "#EDE8E0"

# ─────── CONSTANTS ─────────────────────────────────────────────
# General constants (null, undefined, NaN)
color-link constant "#DA7756"
# Boolean values (true, false)
color-link constant.bool "blue"
# Numbers (integers, floats)
color-link constant.number "#DA7756"
# String literals ("text", 'text', `text`)
color-link constant.string "green"
# Escape sequences (\n, \t, \")
color-link constant.specialChar "#4EC2C2"

# ─────── STATEMENTS & SYMBOLS ─────────────────────────────────
# Control flow (if, else, for, while, return)
color-link statement "#C96642"
# General punctuation, braces, semicolons
color-link symbol "#9A928A"
# Parentheses, brackets, braces: ( ) [ ] { }
color-link symbol.brackets "#DA7756"
# Arithmetic/logical operators: + - * / && || ==
color-link symbol.operator "#DA7756"
# HTML/XML tags: <div>, </span>
color-link symbol.tag "#C96642"

# ─────── PREPROCESSOR & SPECIAL ───────────────────────────────
# Includes, imports, defines (#include, import, using)
color-link preproc "#A584E0"
# Shebang line: #!/usr/bin/env python
color-link preproc.shebang "#6B6560"
# Special language constructs (decorators, annotations)
color-link special "#A584E0"
# Links, URLs, references
color-link underlined "underline blue"

# ─────── TYPES ─────────────────────────────────────────────────
# Type annotations (string, int, bool, custom types)
color-link type "#C96642"
# Type-specific keywords (typedef, typename, class)
color-link type.keyword "#C96642"

# ─────── STATUS & MESSAGING ───────────────────────────────────
# Syntax errors, invalid syntax
color-link error "red"
# TODO, FIXME, XXX comments
color-link todo "#D4943A"
# Info messages in status bar
color-link message "#EDE8E0"
# Error messages in status bar
color-link error-message "red"

# ─────── DIFF (Version Control) ───────────────────────────────
# Lines added (git add)
color-link diff-added "green"
# Lines modified (git modify)
color-link diff-modified "blue"
# Lines deleted (git remove)
color-link diff-deleted "red"

# ─────── GUTTER (Line number area) ────────────────────────────
# Normal line numbers
color-link gutter-info "#6B6560"
# Error marker in gutter
color-link gutter-error "red"
# Warning marker in gutter
color-link gutter-warning "yellow"

# ─────── INTERFACE ELEMENTS ───────────────────────────────────
# Main status line (foreground,background)
color-link statusline "#1F1E1C,#EDE8E0"
# Inactive split panes status line
color-link statusline.inactive "#262422,#9A928A"
# Autocomplete suggestions menu
color-link statusline.suggestions "#262422,#EDE8E0"
# Tab bar background
color-link tabbar "#1F1E1C,#9A928A"
# Active tab highlight
color-link tabbar.active "#1F1E1C,#EDE8E0"
# Indentation guide characters
color-link indent-char "#35322E"
# Absolute line numbers (left gutter)
color-link line-number "#6B6560"
# Relative line number (current line)
color-link current-line-number "#EDE8E0"
# Background of line with cursor
color-link cursor-line "#1F1E1C,#EDE8E0"
# Column ruler (if colorcolumn is set)
color-link color-column "#35322E"
# Selected text background
color-link selection "bold #1A1917,#EDE8E0"
# Split pane divider lines
color-link divider "#35322E"
# Matching bracket highlight
color-link match-brace "#DA7756"
# Search result highlights
color-link hlsearch "#3D3A35"
# Mixed tab/space errors
color-link tab-error "red"
# Trailing whitespace indicator
color-link trailingws "red"
# Ignored files in file browser
color-link ignore "#6B6560"
