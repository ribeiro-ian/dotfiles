#!/usr/bin/env bash
NUM="${1:-0}"
FILENAME="${NUM}.cpp"

if [[ -f $FILENAME ]]; then
    echo "File already exists!"
    echo "opening $FILENAME..."
    codium "$FILENAME"
    exit 1
fi

printf '%s\n' \
    '/**'\
    " * Contest : CSES Problem Set"\
    " * Problem : ${NUM} - TITLE"\
    " * Link    : https://cses.fi/problemset/task/${NUM}"\
    " * Time    : O(???)"\
    ' */'\
    '' \
    > "$FILENAME"

codium "$FILENAME"
