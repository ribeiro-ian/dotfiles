#!/usr/bin/env bash
# Usage:
#   run file.cpp
#   run file.cpp in.txt
#   run file.cpp in.txt out.txt
#   run file.cpp < in.txt > out.txt  (shell redirection, works normally)

set -e

src="$1"
input="$2"
output="$3"

if [[ -z "$src" ]]; then
    echo "Usage: run <file.cpp [input] [output]" >&2
    exit 1
fi

if [[ ! -f "$src" ]]; then
    echo "run: file not found: $src" >&2
    exit 1
fi

bin="$(dirname "$src")/a.out"

if [[ ! -f "$bin" || "$src" -nt "$bin" ]]; then
    echo "Compiling..." >&2
    g++ -O2 -Wall -Wshadow -o "$bin" "$src"
fi

if [[ -n "$input" && -n "$output" ]]; then
    time "$bin" < "$input" > "$output"
elif [[ -n "$input" ]]; then
    time "$bin" < "$input"
else
    time "$bin"
fi
