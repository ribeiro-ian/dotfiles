{
	// Place your snippets for cpp here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console":{
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }

	"Default competitive programming code" :{
		"prefix": "code",
		"body" : [
			"#include <bits/stdc++.h>",
			"using namespace std;",
			"using ll = long long;",
			"",
			"#define fastio ios::sync_with_stdio(0); cin.tie(0);",
			"",
			"int main() {",
			"\tfastio",
			"",
			"\t${0://code}",
			"",
			"\treturn 0;",
			"}",
		],
		"description": "Competitive Programming exercises default init",
	},
	
	"Default competitive programming code with test cases" :{
		"prefix": "codetc",
		"body" : [
			"#include <bits/stdc++.h>",
			"using namespace std;",
			"using ll = long long;",
			"",
			"#define fastio ios::sync_with_stdio(0); cin.tie(0);",
			"",
			"void solve() {",
			"\t${0://code}",
			"}",
			"",
			"int main() {",
			"\tfastio",
			"",
			"\tint tc; cin >> tc;",
			"\twhile (tc--) solve();",
			"",
			"\treturn 0;",
				"}",
		],
		"description": "Competitive Programming exercises default init with test cases",
	},
	
	"Problem info":{
		"prefix": "header",
		"body": [
			"/*",
			"\t${2:// title}",
			"\t${1:// link}",
			"*/",
			"${3}"
		],
		"description": "Custom for loop snippet"
	},
	
	"For Loop":{
		"prefix": "for",
		"body": [
			"for (int ${1:i} = ${2:0}; ${1:i} < ${3:count}; ++${1:i}) {",
			"\t${4:// code}",
			"}"
		],
		"description": "Custom for loop snippet"
	},

	"Reverse For Loop":{
		"prefix": "forr",
		"body": [
			"for (int ${1:i} = ${2:count}; ${1:i} >= ${3:0}; --${1:i}) {",
			"\t${4:// code}",
			"}"
		],
		"description": "Custom reverse for loop snippet"
	},

	"For Each Loop":{
		"prefix": "forauto",
		"body": [
			"for (auto& ${1:i} : ${2:v}) {",
			"\t${3:// code}",
			"}"
		],
		"description": "Custom for auto loop snippet"
	},

	"While Loop":{
		"prefix": "while",
		"body": [
			"while (${1:condition}) {",
			"\t${2:// code}",
			"}"
		],
		"description": "Custom while loop snippet"
	},

	"If Statement":{
		"prefix": "if",
		"body": [
			"if (${1:condition}) {",
			"\t${2:// code}",
			"}"
		],
		"description": "Custom if statement snippet"
	},

	"Main Function":{
		"prefix": "main",
		"body": [
			"int main() {",
			"\tfastio",
			"",
			"\t${1:// code}",
			"",
			"\treturn 0;",
			"}"
		],
		"description": "Custom main function snippet"
	}

	
}